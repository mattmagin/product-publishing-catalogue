{
  "name": "universal-store-product-publishing-catalogue",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "pnpm -r --if-present dev",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "api:build": "docker compose build api",
    "api:dev": "docker compose up api",
    "api:setup": "docker compose run --rm api bin/rails db:prepare",
    "api:test": "docker compose run --rm -e RAILS_ENV=test api bin/rails test",
    "api:console": "docker compose run --rm api bin/rails console",
    "api:shell": "docker compose run --rm api bash",
    "frontend:dev": "pnpm --filter product-publishing-frontend dev",
    "frontend:build": "pnpm --filter product-publishing-frontend build",
    "frontend:preview": "pnpm --filter product-publishing-frontend preview",
    "frontend:lint": "pnpm --filter product-publishing-frontend lint"
  }
}
